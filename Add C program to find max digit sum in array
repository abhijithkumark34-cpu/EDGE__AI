// Online C compiler to run C program online
#include <stdio.h>

int main() {
    int  n, i, max=0, maxarray=0;
    printf("Enter the number of elemants in the array");
    scanf("%d",&n);
    int a[n];
    printf("Enter the number ");
    for(i=0;i<n;i++){
        scanf("%d",&a[i]);
        
    }
    for(i=0;i<n;i++){
        int sum=0;

        
        while(a[i]!=0){
            int rem=a[i]%10;
            sum=sum+rem;
            a[i]=a[i]/10;
            
        }
        if(max<sum){
            max=sum;
            maxarray=i;
        }
        
    }
    printf("the maximum sum of the digit is %d and the position is %d",max,maxarray+1);

    return 0;
}
