#include <stdio.h>
#include<string.h>

int main() {
    char d[10];
     printf("Enter the string");
    scanf("%s",d);
    int n=strlen(d);
    
    for(int i=0;i<n;i++){
        int count =1;
        while(i+1<n&&d[i]==d[i+1]){
            count++;
            i++;
        }
        printf("%c%d",d[i],count);
        
       
            }
            
       
    

    return 0;
}
